    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib as mpl\n",
    "import warnings, random, os\n",
    "import seaborn as sns\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "mpl.rcParams['figure.dpi'] = 150\n",
    "sns.set(style=\"whitegrid\")\n",
    "\n",
    "SEED = 42\n",
    "random.seed(SEED)\n",
    "np.random.seed(SEED)\n",
    "os.environ['PYTHONHASHSEED'] = str(SEED)\n",
    "\n",
    "from pathlib import Path\n",
    "from prophet import Prophet\n",
    "from prophet.make_holidays import make_holidays_df\n",
    "from sklearn.metrics import mean_squared_error, mean_absolute_percentage_error\n",
    "\n",
    "# =========================================================\n",
    "# 1 — LOAD DATA\n",
    "# =========================================================\n",
    "cwd = Path.cwd()\n",
    "print(f'Notebook cwd: {cwd}')\n",
    "\n",
    "candidates = [\n",
    "    Path('Data/processed/clean_data'),\n",
    "    Path('processed/clean_data'),\n",
    "    Path('..') / 'processed' / 'clean_data',\n",
    "    Path('..') / '..' / 'processed' / 'clean_data',\n",
    "    Path('..') / '..' / '..' / 'processed' / 'clean_data'\n",
    "]\n",
    "DATA_DIR = next((p for p in candidates if p.exists()), None)\n",
    "if DATA_DIR is None:\n",
    "    raise FileNotFoundError(\n",
    "        'Không tìm thấy thư mục clean_data. ' \\\n",
    "        'Hãy kiểm tra lại thư mục làm việc của kernel hoặc sửa DATA_DIR.'\n",
    "    )\n",
    "DATA_DIR = DATA_DIR.resolve()\n",
    "print(f'Using DATA_DIR = {DATA_DIR}')\n",
    "\n",
    "files    = sorted(DATA_DIR.glob('clean_2021-*.parquet'))\n",
    "print(f'Number of files: {len(files)}')\n",
    "\n",
    "columns = ['tpep_pickup_datetime', 'total_amount', 'trip_distance', 'speed_mph']\n",
    "daily_aggregates = []\n",
    "\n",
    "for path in files:\n",
    "    print('Loading', path.name)\n",
    "    df = pd.read_parquet(path, columns=columns)\n",
    "    df['pickup_date'] = df['tpep_pickup_datetime'].dt.floor('D')\n",
    "    daily_part = df.groupby('pickup_date', as_index=False).agg(\n",
    "        trip_count=('total_amount', 'size'),\n",
    "        revenue=('total_amount', 'sum'),\n",
    "        avg_trip_distance=('trip_distance', 'mean'),\n",
    "        avg_speed=('speed_mph', 'mean')\n",
    "    )\n",
    "    daily_aggregates.append(daily_part)\n",
    "\n",
    "daily = pd.concat(daily_aggregates, ignore_index=True)\n",
    "daily = daily.groupby('pickup_date', as_index=False).agg(\n",
    "    trip_count=('trip_count', 'sum'),\n",
    "    revenue=('revenue', 'sum'),\n",
    "    avg_trip_distance=('avg_trip_distance', 'mean'),\n",
    "    avg_speed=('avg_speed', 'mean')\n",
    ")\n",
    "daily = daily.sort_values('pickup_date').reset_index(drop=True)\n",
    "print(f\"Tổng số ngày: {len(daily)}\")\n",
    "\n",
    "# =========================================================\n",
    "# 2 — TRAIN/TEST SPLIT\n",
    "# =========================================================\n",
    "TEST_DAYS = 60\n",
    "\n",
    "prophet_df = daily[['pickup_date','revenue']].rename(\n",
    "    columns={'pickup_date':'ds','revenue':'y'})\n",
    "\n",
    "train_p = prophet_df.iloc[:-TEST_DAYS].copy()\n",
    "test_p  = prophet_df.iloc[-TEST_DAYS:].copy()\n",
    "train_p['trip_count'] = daily['trip_count'].iloc[:-TEST_DAYS].values\n",
    "test_p['trip_count']  = daily['trip_count'].iloc[-TEST_DAYS:].values\n",
    "y_test = test_p['y'].values\n",
    "\n",
    "# =========================================================\n",
    "# 3 — TRAIN PROPHET GỐC (không holidays)\n",
    "# =========================================================\n",
    "model = Prophet(\n",
    "    weekly_seasonality=True,\n",
    "    yearly_seasonality=False,\n",
    "    daily_seasonality=False,\n",
    "    seasonality_mode='multiplicative',\n",
    "    changepoint_prior_scale=0.05,\n",
    "    seasonality_prior_scale=5.0\n",
    ")\n",
    "model.add_seasonality('monthly', period=30.5, fourier_order=3)\n",
    "model.add_regressor('trip_count')\n",
    "model.fit(train_p)\n",
    "\n",
    "pred_test = model.predict(test_p[['ds','trip_count']])['yhat'].values\n",
    "rmse = np.sqrt(mean_squared_error(y_test, pred_test))\n",
    "mape = mean_absolute_percentage_error(y_test, pred_test)\n",
    "print(f\"\\nProphet gốc | RMSE={rmse:,.0f} | MAPE={mape*100:.1f}%\")\n",
    "\n",
    "# =========================================================\n",
    "# 4 — TRAIN PROPHET + HOLIDAYS\n",
    "# =========================================================\n",
    "us_holidays = make_holidays_df(year_list=[2021], country='US')\n",
    "\n",
    "model_h = Prophet(\n",
    "    weekly_seasonality=True,\n",
    "    yearly_seasonality=False,\n",
    "    daily_seasonality=False,\n",
    "    seasonality_mode='multiplicative',\n",
    "    changepoint_prior_scale=0.05,\n",
    "    seasonality_prior_scale=5.0,\n",
    "    holidays=us_holidays,\n",
    "    holidays_prior_scale=10.0\n",
    ")\n",
    "model_h.add_seasonality('monthly', period=30.5, fourier_order=3)\n",
    "model_h.add_regressor('trip_count')\n",
    "model_h.fit(train_p)\n",
    "\n",
    "pred_h     = model_h.predict(test_p[['ds','trip_count']])\n",
    "pred_h_val = pred_h['yhat'].values\n",
    "rmse_h     = np.sqrt(mean_squared_error(y_test, pred_h_val))\n",
    "mape_h     = mean_absolute_percentage_error(y_test, pred_h_val)\n",
    "print(f\"Prophet+holidays | RMSE={rmse_h:,.0f} | MAPE={mape_h*100:.1f}%\")\n",
    "\n",
    "best_model = model_h if mape_h <= mape else model\n",
    "best_pred  = pred_h_val if mape_h <= mape else pred_test\n",
    "best_mape  = min(mape_h, mape)\n",
    "print(f\"→ Dùng: {'Prophet+holidays' if mape_h <= mape else 'Prophet gốc'}\")\n",
    "\n",
    "# =========================================================\n",
    "# 5 — RETRAIN TOÀN BỘ DATA để forecast tương lai\n",
    "# =========================================================\n",
    "full_df               = prophet_df.copy()\n",
    "full_df['trip_count'] = daily['trip_count'].values\n",
    "\n",
    "model_full_h = Prophet(\n",
    "    weekly_seasonality=True,\n",
    "    yearly_seasonality=False,\n",
    "    daily_seasonality=False,\n",
    "    seasonality_mode='multiplicative',\n",
    "    changepoint_prior_scale=0.05,\n",
    "    seasonality_prior_scale=5.0,\n",
    "    holidays=us_holidays,\n",
    "    holidays_prior_scale=10.0\n",
    ")\n",
    "model_full_h.add_seasonality('monthly', period=30.5, fourier_order=3)\n",
    "model_full_h.add_regressor('trip_count')\n",
    "model_full_h.fit(full_df)\n",
    "\n",
    "last_trip_avg = daily['trip_count'].tail(14).mean()\n",
    "future        = model_full_h.make_future_dataframe(periods=30)\n",
    "future['trip_count'] = last_trip_avg\n",
    "fc_full = model_full_h.predict(future)\n",
    "print(\"Retrain + forecast 30 ngày xong!\")\n",
    "\n",
    "# =========================================================\n",
    "# BIỂU ĐỒ 1 — Forecast vs Actual + holidays\n",
    "# =========================================================\n",
    "holiday_dates = us_holidays[\n",
    "    us_holidays['ds'].between(test_p['ds'].min(), test_p['ds'].max())\n",
    "]['ds']\n",
    "\n",
    "fig, axes = plt.subplots(2, 1, figsize=(14, 10))\n",
    "\n",
    "ax = axes[0]\n",
    "ax.plot(test_p['ds'], y_test,    label='Actual', lw=2, color='black')\n",
    "ax.plot(test_p['ds'], best_pred, label=f'Prophet (MAPE={best_mape*100:.1f}%)', lw=2, color='tab:green')\n",
    "ax.fill_between(test_p['ds'],\n",
    "                pred_h['yhat_lower'].values, pred_h['yhat_upper'].values,\n",
    "                color='tab:green', alpha=0.15, label='Confidence interval')\n",
    "for hdate in holiday_dates:\n",
    "    ax.axvline(pd.Timestamp(hdate), color='red', linestyle='--', lw=1.2, alpha=0.7)\n",
    "ax.set_title('Prophet — Forecast vs Actual | Vạch đỏ = ngày lễ')\n",
    "ax.set_ylabel('Revenue')\n",
    "ax.legend()\n",
    "plt.setp(ax.xaxis.get_majorticklabels(), rotation=35)\n",
    "\n",
    "ax2 = axes[1]\n",
    "res = y_test - best_pred\n",
    "ax2.bar(test_p['ds'], res, color=np.where(res>=0,'steelblue','tomato'), alpha=0.7)\n",
    "ax2.axhline(0, color='black', lw=1)\n",
    "ax2.set_title('Residuals | Đều quanh 0 = tốt')\n",
    "ax2.set_ylabel('Actual − Predicted')\n",
    "plt.setp(ax2.xaxis.get_majorticklabels(), rotation=35)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# =========================================================\n",
    "# BIỂU ĐỒ 2 — Holiday effect %\n",
    "# =========================================================\n",
    "holiday_comp = fc_full[['ds','holidays']].copy()\n",
    "holiday_comp = holiday_comp[holiday_comp['holidays'] != 0].copy()\n",
    "holiday_comp['effect_pct'] = holiday_comp['holidays'] * 100\n",
    "holiday_comp = holiday_comp.merge(us_holidays, on='ds', how='left')\n",
    "\n",
    "if len(holiday_comp) > 0:\n",
    "    fig, ax = plt.subplots(figsize=(12, 4))\n",
    "    bars = ax.bar(holiday_comp['holiday'], holiday_comp['effect_pct'],\n",
    "                  color=np.where(holiday_comp['effect_pct']>=0,'steelblue','tomato'), alpha=0.8)\n",
    "    ax.axhline(0, color='black', lw=1)\n",
    "    ax.set_title('Holiday Effect — % thay đổi doanh thu so với ngày thường')\n",
    "    ax.set_ylabel('Effect (%)')\n",
    "    plt.setp(ax.xaxis.get_majorticklabels(), rotation=45, ha='right')\n",
    "    for bar, val in zip(bars, holiday_comp['effect_pct']):\n",
    "        ax.text(bar.get_x() + bar.get_width()/2,\n",
    "                val + 0.5 if val >= 0 else val - 1,\n",
    "                f'{val:.1f}%', ha='center', va='bottom', fontsize=8)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "# =========================================================\n",
    "# BIỂU ĐỒ 3 — Revenue theo thứ trong tuần\n",
    "# =========================================================\n",
    "daily['dow_name']   = daily['pickup_date'].dt.day_name()\n",
    "daily['month_name'] = daily['pickup_date'].dt.strftime('%b')\n",
    "month_order = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']\n",
    "dow_order   = ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday']\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 4))\n",
    "dow_avg = daily.groupby('dow_name')['revenue'].mean().reindex(dow_order)\n",
    "bars3 = ax.bar(dow_avg.index, dow_avg.values,\n",
    "               color=['tomato' if d in ['Saturday','Sunday'] else 'steelblue' for d in dow_avg.index],alpha=0.8)\n",
    "for bar, val in zip(bars3, dow_avg.values):\n",
    "    ax.text(bar.get_x() + bar.get_width()/2, val + dow_avg.max()*0.01,\n",
    "            f'{val:,.0f}', ha='center', va='bottom', fontsize=8)\n",
    "ax.set_title('Revenue trung bình theo thứ | Đỏ = cuối tuần')\n",
    "ax.set_ylabel('Avg Revenue')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# =========================================================\n",
    "# BIỂU ĐỒ 4 — Revenue trung bình theo tháng\n",
    "# =========================================================\n",
    "fig, ax = plt.subplots(figsize=(12, 4))\n",
    "month_avg = daily.groupby(daily['pickup_date'].dt.month)['revenue'].agg(['mean','std'])\n",
    "month_avg.index = month_order\n",
    "bars4 = ax.bar(month_avg.index, month_avg['mean'], yerr=month_avg['std'],\n",
    "               capsize=4, color='steelblue', alpha=0)\n",
    "for bar, val in zip(bars4, month_avg['mean']):\n",
    "    ax.text(bar.get_x() + bar.get_width()/2, val + month_avg['std'].max()*0.05,\n",
    "            f'{val/1e6:.1f}M', ha='center', va='bottom', fontsize=8)\n",
    "ax.set_title('Revenue trung bình theo tháng ± std')\n",
    "ax.set_ylabel('Avg Revenue')\n",
    "plt.setp(ax.xaxis.get_majorticklabels(), rotation=45)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# =========================================================\n",
    "# BIỂU ĐỒ 5 — Boxplot theo tháng\n",
    "# =========================================================\n",
    "fig, ax = plt.subplots(figsize=(12, 4))\n",
    "monthly_data = [daily[daily['pickup_date'].dt.month == m]['revenue'].values for m in range(1,13)]\n",
    "bp = ax.boxplot(monthly_data, labels=month_order, patch_artist=True)\n",
    "for patch in bp['boxes']:\n",
    "    patch.set_facecolor('lightsteelblue')\n",
    "    patch.set_alpha(0)\n",
    "ax.set_title('Distribution doanh thu theo tháng (Boxplot)')\n",
    "ax.set_ylabel('Revenue')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# =========================================================\n",
    "# BIỂU ĐỒ 6 — Trend + changepoints\n",
    "# =========================================================\n",
    "fig, ax = plt.subplots(figsize=(14, 4))\n",
    "ax.plot(fc_full['ds'], fc_full['trend'], color='tab:purple', lw=2)\n",
    "for cp in model_full_h.changepoints:\n",
    "    ax.axvline(cp, color='red', linestyle='--', lw=0.8, alpha=0.4)\n",
    "cp_effects = model_full_h.params['delta'].mean(axis=0)\n",
    "top_cp_idx = np.argsort(np.abs(cp_effects))[-3:]\n",
    "for idx in top_cp_idx:\n",
    "    cp = model_full_h.changepoints.iloc[idx]\n",
    "    ax.axvline(cp, color='darkred', linestyle='--', lw=1.5)\n",
    "    ax.text(cp, fc_full['trend'].min(), cp.strftime('%b %d'),\n",
    "            rotation=90, fontsize=8, color='darkred', va='bottom')\n",
    "ax.set_title('Trend component | Vạch đỏ đậm = điểm thay đổi xu hướng lớn nhất')\n",
    "ax.set_ylabel('Trend')\n",
    "plt.setp(ax.xaxis.get_majorticklabels(), rotation=35)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# =========================================================\n",
    "# BIỂU ĐỒ 7 — Histogram\n",
    "# =========================================================\n",
    "fig, ax = plt.subplots(figsize=(10, 4))\n",
    "ax.hist(daily['revenue'], bins=30, color='steelblue', alpha=0.8, edgecolor='white')\n",
    "ax.axvline(daily['revenue'].mean(),   color='red',    linestyle='--', lw=2,\n",
    "           label=f\"Mean: {daily['revenue'].mean():,.0f}\")\n",
    "ax.axvline(daily['revenue'].median(), color='orange', linestyle='--', lw=2,\n",
    "           label=f\"Median: {daily['revenue'].median():,.0f}\")\n",
    "ax.set_title('Distribution doanh thu hàng ngày')\n",
    "ax.set_xlabel('Revenue')\n",
    "ax.set_ylabel('Số ngày')\n",
    "ax.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "# =========================================================\n",
    "# BIỂU ĐỒ 8 — Heatmap Revenue theo Tháng × Thứ trong tuần\n",
    "# =========================================================\n",
    "fig, ax = plt.subplots(figsize=(13, 5))\n",
    "\n",
    "daily['dow_name']   = daily['pickup_date'].dt.day_name()\n",
    "daily['month_name'] = daily['pickup_date'].dt.strftime('%b')\n",
    "\n",
    "heatmap_data = daily.pivot_table(\n",
    "    index='dow_name', columns='month_name',\n",
    "    values='revenue', aggfunc='mean'\n",
    ").reindex(index=dow_order, columns=month_order)\n",
    "\n",
    "sns.heatmap(\n",
    "    heatmap_data / 1e6,\n",
    "    ax=ax,\n",
    "    cmap='YlOrRd',\n",
    "    annot=True, fmt='.2f',\n",
    "    linewidths=0.5,\n",
    "    cbar_kws={'label': 'Avg Revenue (triệu $)'}\n",
    ")\n",
    "ax.set_title('Heatmap Revenue trung bình (triệu $) — Tháng × Thứ')\n",
    "ax.set_xlabel('Tháng')\n",
    "ax.set_ylabel('Thứ')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# =========================================================\n",
    "# BIỂU ĐỒ 9 — Lag correlation chart\n",
    "# Tự vẽ không cần statsmodels, không bị lỗi trống\n",
    "# =========================================================\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 4))\n",
    "\n",
    "# Scatter: revenue hôm nay vs hôm qua\n",
    "ax = axes[0]\n",
    "ax.scatter(daily['revenue'].shift(1), daily['revenue'],\n",
    "           alpha=0.4, color='steelblue', s=15)\n",
    "corr1 = daily['revenue'].corr(daily['revenue'].shift(1))\n",
    "ax.set_title(f'Revenue hôm nay vs hôm qua | corr={corr1:.2f}')\n",
    "ax.set_xlabel('Revenue ngày t-1')\n",
    "ax.set_ylabel('Revenue ngày t')\n",
    "\n",
    "# Scatter: revenue hôm nay vs cùng ngày tuần trước\n",
    "ax2 = axes[1]\n",
    "ax2.scatter(daily['revenue'].shift(7), daily['revenue'],\n",
    "            alpha=0.4, color='tab:orange', s=15)\n",
    "corr7 = daily['revenue'].corr(daily['revenue'].shift(7))\n",
    "ax2.set_title(f'Revenue hôm nay vs tuần trước | corr={corr7:.2f}')\n",
    "ax2.set_xlabel('Revenue ngày t-7')\n",
    "ax2.set_ylabel('Revenue ngày t')\n",
    "\n",
    "plt.suptitle('Lag Correlation — corr gần 1.0 = pattern mạnh', y=1.02)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# =========================================================\n",
    "# BIỂU ĐỒ 10 — Forecast 30 ngày tương lai\n",
    "# =========================================================\n",
    "future_30_dates = fc_full['ds'].tail(30)\n",
    "future_30_yhat  = fc_full['yhat'].tail(30)\n",
    "future_30_lower = fc_full['yhat_lower'].tail(30)\n",
    "future_30_upper = fc_full['yhat_upper'].tail(30)\n",
    "future_holidays = us_holidays[us_holidays['ds'].isin(future_30_dates)]\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(14, 5))\n",
    "ax.plot(daily['pickup_date'], daily['revenue'],\n",
    "        label='Historical', color='tab:blue', lw=1.5, alpha=0.7)\n",
    "ax.plot(future_30_dates, future_30_yhat,\n",
    "        label='Forecast 30 ngày', color='tab:green', lw=2.5)\n",
    "ax.fill_between(future_30_dates, future_30_lower, future_30_upper,\n",
    "                color='tab:green', alpha=0.2, label='Confidence interval')\n",
    "for _, row in future_holidays.iterrows():\n",
    "    ax.axvline(pd.Timestamp(row['ds']), color='red', linestyle='--', lw=1.5)\n",
    "    ax.text(pd.Timestamp(row['ds']), future_30_yhat.max(),\n",
    "            row['holiday'], rotation=90, fontsize=8, color='red', va='top')\n",
    "ax.axvline(daily['pickup_date'].max(), color='gray', linestyle='--', lw=1.5, label='Hôm nay')\n",
    "ax.set_title('Prophet+Holidays — 30-day Revenue Forecast')\n",
    "ax.set_ylabel('Revenue')\n",
    "ax.legend()\n",
    "plt.xticks(rotation=35)\n",
    "plt.tight_layout()\n",
    "plt.show() "
   ]
  }
